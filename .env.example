# PostgreSQL
POSTGRES_PASSWORD=ragpassword123

# RabbitMQ
RABBITMQ_USER=raguser
RABBITMQ_PASS=ragpassword123

# MinIO (local S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Grafana
GRAFANA_PASSWORD=admin

# API Keys (comma-separated list of valid API keys)
API_KEYS=dev-api-key-1,dev-api-key-2

# Model init
FORCE_MODEL_REINIT=false

# Optional: HuggingFace token for private models
# HF_TOKEN=

# OCR back-end selection
# Set USE_OCR_API=true to route OCR through the ocr-api REST service (uses
# OpenAI GPT-4o-mini) instead of running Tesseract locally.  When false (the
# default) the ocr-service runs Tesseract in-process.
USE_OCR_API=false

# Required when USE_OCR_API=true
# OPENAI_API_KEY=sk-...
